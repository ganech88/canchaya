{
  "name": "canchaya",
  "version": "0.1.0",
  "private": true,
  "description": "CanchaYa — marketplace de reserva de canchas deportivas (LATAM)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "db:types": "supabase gen types typescript --local > packages/db/src/types.generated.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "mobile": "pnpm --filter @canchaya/mobile",
    "web": "pnpm --filter @canchaya/web"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "prettier": "^3.3.3",
    "supabase": "^1.207.9",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
