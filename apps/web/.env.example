NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Sólo para server actions / route handlers, nunca exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL de descarga del APK. Si está definido, el banner de Android y /app apuntan
# directo al archivo; si no, /app muestra instrucciones de Expo Go.
# Ejemplo (cuando EAS Build termina):
#   NEXT_PUBLIC_ANDROID_APK_URL=https://expo.dev/artifacts/eas/xxxxxxxxxxx.apk
NEXT_PUBLIC_ANDROID_APK_URL=
