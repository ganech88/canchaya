# ── Nhost ──────────────────────────────────────────────
# Subdomain y region del proyecto Nhost. Mirá nhost-canchaya.md en memoria
# para los valores reales del proyecto sa-east-1.
NHOST_SUBDOMAIN=your-project-subdomain
NHOST_REGION=sa-east-1
# Sólo server-side (route handlers, scripts). NUNCA bundle cliente.
NHOST_ADMIN_SECRET=your-admin-secret

# App mobile (Expo)
EXPO_PUBLIC_NHOST_SUBDOMAIN=${NHOST_SUBDOMAIN}
EXPO_PUBLIC_NHOST_REGION=${NHOST_REGION}

# Dashboard web (Next.js)
NEXT_PUBLIC_NHOST_SUBDOMAIN=${NHOST_SUBDOMAIN}
NEXT_PUBLIC_NHOST_REGION=${NHOST_REGION}

# ── Mapbox (mapa usuario) — pendiente de integración con @rnmapbox/maps
# Requiere dev build (no funciona en Expo Go).
# EXPO_PUBLIC_MAPBOX_TOKEN=pk.xxx

# ── Mercado Pago (pagos)
# Las Functions en nhost/functions/ leen estos env vars al deployarse.
# Setear via Nhost dashboard → Settings → Environment Variables.
# MP_ACCESS_TOKEN=APP_USR-xxx                  # APP_USR-... del marketplace MP
# MP_WEBHOOK_SECRET=xxx                        # secret para validar firma de webhook (HMAC-SHA256)
# APP_URL=https://canchaya.vercel.app          # base URL del web (back_urls de checkout)
# NHOST_FUNCTIONS_URL=https://<subdomain>.functions.<region>.nhost.run
# APP_DEEP_LINK=canchaya://                    # scheme del mobile para redirects
