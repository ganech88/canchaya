# ── Supabase ───────────────────────────────────────────
# Copiado para ambos apps — los apps usan el prefijo correspondiente.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# App mobile (Expo)
EXPO_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
EXPO_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# Dashboard web (Next.js)
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# ── Mapbox (mapa usuario) — integrar cuando se implemente ScreenMap
# EXPO_PUBLIC_MAPBOX_TOKEN=pk.xxx

# ── Mercado Pago (pagos) — integrar al llegar al flujo de pago
# MP_ACCESS_TOKEN=APP_USR-xxx
# MP_WEBHOOK_SECRET=xxx
